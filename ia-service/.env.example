# ia-service/.env.example
# En Docker Compose estos defaults ya funcionan por nombre de servicio.

# --- Ollama ---
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b-instruct-q4_K_M
OLLAMA_TEMPERATURE=0.2
OLLAMA_TIMEOUT_SECONDS=90

# --- ChromaDB ---
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=deportedata_docs

# --- Moderador ---
# Umbral 0..1 para marcar un mensaje como tóxico (Detoxify multilingual).
TOXIC_THRESHOLD=0.5

# --- Servicio ---
PORT=8100
DATA_JSON_DIR=/data_json
